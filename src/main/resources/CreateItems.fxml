      </TextField>
      <TextField fx:id="giaKhoiDau" alignment="CENTER" layoutX="134.0" layoutY="275.0" prefHeight="57.0" prefWidth="398.0" promptText="Giá khởi đầu" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-border-radius: 30; -fx-background-radius: 30; -fx-text-fill: white;">
