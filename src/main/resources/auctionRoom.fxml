<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1000.0" style="-fx-background-color: #1E1E1D;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AuctionRoomController">

    <children>
        <BorderPane prefHeight="750.0" prefWidth="1000.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-border-width: 0 0 2 0;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 24px; -fx-font-weight: bold;" text="PHÒNG ĐẤU GIÁ" />
                        <Region prefHeight="35.0" prefWidth="445.0" HBox.hgrow="ALWAYS" />
                        <Label prefHeight="20.0" prefWidth="46.0" style="-fx-text-fill: #eacd8f; -fx-font-size: 14px;" text="Số dư:" />
                        <Label fx:id="userBalanceLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 16px; -fx-font-weight: bold;" text="300,000 $" />
                    </children>
                </HBox>
            </top>

            <center>
                <SplitPane dividerPositions="0.32" style="-fx-background-color: #1E1E1D; -fx-box-border: transparent; -fx-padding: 0;" BorderPane.alignment="CENTER">
                    <items>
                        <VBox minWidth="260.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-border-width: 0 1 0 0;">
                            <padding>
                                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
                            </padding>
                            <children>
                                <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 18px; -fx-font-weight: bold;" text="Các phiên đấu giá">
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </Label>

                                <!-- Search Panel -->
                                <VBox spacing="8" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10;" VBox.vgrow="NEVER">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <TextField fx:id="searchKeywordField" promptText="🔍 Tìm kiếm..." style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 13px;" />
                                        <HBox spacing="5">
                                            <ComboBox fx:id="searchCategoryCombo" prefWidth="130.0" promptText="Danh mục" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-font-size: 12px;" />
                                            <ComboBox fx:id="searchStatusCombo" prefWidth="120.0" promptText="Trạng thái" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-font-size: 12px;" />
                                        </HBox>
                                        <HBox spacing="5">
                                            <TextField fx:id="searchMinPriceField" prefWidth="80.0" promptText="Giá từ" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 12px;" />
                                            <TextField fx:id="searchMaxPriceField" prefWidth="80.0" promptText="Giá đến" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 12px;" />
                                            <ComboBox fx:id="searchSortCombo" prefWidth="85.0" promptText="Sắp xếp" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-font-size: 12px;" />
                                        </HBox>
                                        <HBox spacing="5">
                                            <Button onAction="#searchAuctions" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-font-size: 12px;" text="Tìm kiếm" HBox.hgrow="ALWAYS" />
                                            <Button onAction="#resetSearch" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-size: 12px;" text="Xóa lọc" HBox.hgrow="ALWAYS" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <ScrollPane fx:id="auctionListScrollPane" fitToWidth="true" focusTraversable="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                    <content>
                                        <VBox fx:id="auctionList" spacing="10" style="-fx-background-color: transparent;" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <VBox fx:id="auctionDetailPane" minWidth="450.0" style="-fx-background-color: #1E1E1D;" visible="false">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <!-- Tiêu đề sản phẩm cố định phía trên -->
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label fx:id="selectedAuctionName" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Tên sản phẩm" />
                                        <Button fx:id="watchlistToggleButton" onAction="#toggleWatchlist" style="-fx-background-color: transparent; -fx-text-fill: #eacd8f; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 0 10;" text="☆" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button onAction="#backToList" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 20;" text="X">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Button>
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </HBox>

                                <!-- SplitPane Dọc để thay đổi kích thước linh hoạt giữa thông tin đấu giá và lịch sử/chat -->
                                <SplitPane orientation="VERTICAL" dividerPositions="0.55" style="-fx-background-color: transparent; -fx-box-border: transparent;" VBox.vgrow="ALWAYS">
                                    <items>
                                        <!-- Phần 1: Thông tin chi tiết & Đặt giá (Bọc ScrollPane để cuộn khi bị thu nhỏ dọc) -->
                                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #1E1E1D; -fx-border-color: transparent;" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                                            <content>
                                                <VBox spacing="10" style="-fx-background-color: #1E1E1D;">
                                                    <padding>
                                                        <Insets bottom="10.0" left="2.0" right="10.0" top="2.0" />
                                                    </padding>
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="20">
                                                            <children>
                                                                <Label fx:id="selectedAuctionStatus" style="-fx-text-fill: #eacd8f; -fx-font-size: 14px;" text="Trang thai: RUNNING" />
                                                                <Label fx:id="durationDisplayLabel" style="-fx-text-fill: #888888; -fx-font-size: 13px;" text="Thời gian: 60 phút" />
                                                            </children>
                                                        </HBox>

                                                        <HBox alignment="CENTER" spacing="30" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 15;">
                                                            <children>
                                                                <VBox alignment="CENTER" spacing="5">
                                                                    <children>
                                                                        <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="THỜI GIAN CÒN LẠI" />
                                                                        <Label fx:id="timerLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 24px; -fx-font-weight: bold;" text="00:00" />
                                                                    </children>
                                                                </VBox>

                                                                <VBox alignment="CENTER" spacing="5">
                                                                    <children>
                                                                        <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="GIÁ HIỆN TẠI" />
                                                                        <Label fx:id="currentPriceLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 24px; -fx-font-weight: bold;" text="100,000 $" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>

                                                        <HBox spacing="15">
                                                            <children>
                                                                <VBox>
                                                                    <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="BẮT ĐẦU" />
                                                                    <Label fx:id="startTimeLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" text="--:--" />
                                                                </VBox>
                                                                <VBox>
                                                                    <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="KẾT THÚC" />
                                                                    <Label fx:id="endTimeLabel" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;" text="--:--" />
                                                                </VBox>
                                                                <VBox>
                                                                    <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="NGƯỜI RA GIÁ CAO NHẤT" />
                                                                    <Label fx:id="highestBidderLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" text="Chưa có" />
                                                                </VBox>
                                                            </children>
                                                        </HBox>

                                                        <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 15px; -fx-font-weight: bold;" text="Đặt giá" />

                                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                                            <children>
                                                                <TextField fx:id="bidAmountField" prefHeight="35.0" prefWidth="180.0" promptText="Nhập số tiền" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 13px;" />
                                                                <Button onAction="#placeBid" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 13px;" text="ĐẶT GIÁ" />
                                                                <Button onAction="#quickBid" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 12px;" text="ĐẶT NHANH" />
                                                            </children>
                                                        </HBox>

                                                        <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 13px; -fx-font-weight: bold;" text="Tự động trả giá" />

                                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                                            <children>
                                                                <CheckBox fx:id="autoBidCheckBox" style="-fx-text-fill: #eacd8f; -fx-font-size: 12px;" text="Bật" />
                                                                <TextField fx:id="autoBidMaxField" prefHeight="30.0" prefWidth="110.0" promptText="Số tối đa" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 12px;" />
                                                                <TextField fx:id="autoBidIncrementField" prefHeight="30.0" prefWidth="90.0" promptText="Bước giá" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 12px;" />
                                                                <Button fx:id="autoBidButton" onAction="#toggleAutoBid" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 11px;" text="Xác nhận" />
                                                            </children>
                                                        </HBox>

                                                        <VBox fx:id="bidChartContainer" prefHeight="130.0" VBox.vgrow="NEVER" />
                                                    </children>
                                                </VBox>
                                            </content>
                                        </ScrollPane>

                                        <!-- Phần 2: TabPane Lịch sử & Chat -->
                                        <TabPane fx:id="auctionTabs" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                                            <tabs>
                                                <Tab text="Lịch sử đặt giá">
                                                    <content>
                                                        <VBox style="-fx-background-color: #1E1E1D; -fx-padding: 10;" spacing="5">
                                                            <children>
                                                                <ScrollPane fx:id="bidHistoryScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" focusTraversable="true">
                                                                    <content>
                                                                        <VBox fx:id="bidHistoryList" spacing="5" style="-fx-background-color: transparent;" />
                                                                    </content>
                                                                </ScrollPane>
                                                            </children>
                                                        </VBox>
                                                    </content>
                                                </Tab>
                                                <Tab text="Trò chuyện trực tuyến">
                                                    <content>
                                                        <VBox spacing="10" style="-fx-background-color: #1E1E1D; -fx-padding: 10;">
                                                            <children>
                                                                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                                                                    <content>
                                                                        <VBox fx:id="chatList" spacing="5" style="-fx-background-color: transparent;" />
                                                                    </content>
                                                                </ScrollPane>
                                                                <HBox spacing="10" alignment="CENTER_LEFT" VBox.vgrow="NEVER">
                                                                    <children>
                                                                        <TextField fx:id="chatInputField" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 13px;" onAction="#sendChatMessage" />
                                                                        <Button onAction="#sendChatMessage" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 13px;" text="Gửi" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                    </content>
                                                </Tab>
                                            </tabs>
                                        </TabPane>
                                    </items>
                                </SplitPane>
                            </children>
                        </VBox>
                    </items>
                </SplitPane>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
