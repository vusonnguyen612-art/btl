<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="523.0" prefWidth="666.0" style="-fx-background-color: #1E1E1D;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AdminPaneController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="495.0" prefWidth="638.0" spacing="10.0">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label alignment="CENTER" prefHeight="40.0" prefWidth="618.0" text="QUẢN TRỊ HỆ THỐNG" textFill="#d4af5a">
               <font>
                  <Font name="Arial Bold" size="24.0" />
               </font>
            </Label>
            <Label text="Danh sách người dùng" textFill="#eacd8f">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TableView fx:id="userTable" prefHeight="340.0" prefWidth="618.0" style="-fx-background-color: #111111; -fx-border-color: #d4af5a;">
               <columns>
                  <TableColumn fx:id="idColumn" prefWidth="100.0" text="ID" />
                  <TableColumn fx:id="usernameColumn" prefWidth="120.0" text="Tên đăng nhập" />
                  <TableColumn fx:id="roleColumn" prefWidth="100.0" text="Vai trò" />
                  <TableColumn fx:id="emailColumn" prefWidth="150.0" text="Email" />
                  <TableColumn fx:id="balanceColumn" prefWidth="120.0" text="Số dư" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER" prefHeight="40.0" prefWidth="618.0" spacing="20.0">
               <children>
                  <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#onRefresh" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #d9b15f; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold;" text="🔄 Làm mới">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#onDeleteUser" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #c0392b; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold;" text="🗑 Xóa người dùng">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <Label fx:id="statusLabel" alignment="CENTER" prefHeight="20.0" prefWidth="618.0" text="Nhấn 'Làm mới' để tải danh sách" textFill="#eacd8f" wrapText="true">
               <font>
                  <Font size="12.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </children>
</AnchorPane>
