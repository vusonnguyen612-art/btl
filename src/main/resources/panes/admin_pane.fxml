<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="AdminPane" prefHeight="523.0" prefWidth="666.0" style="-fx-background-color: #1E1E1D;" visible="false" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AdminPaneController">
   <children>
      <Label layoutX="20.0" layoutY="8.0" text="Quản trị hệ thống" textFill="#eacd8f">
         <font><Font name="Arial Bold" size="20.0" /></font>
      </Label>
      <Label layoutX="20.0" layoutY="42.0" text="Người dùng" textFill="#d4af5a">
         <font><Font name="Arial Bold" size="14.0" /></font>
      </Label>
      <TableView fx:id="userTable" layoutX="20.0" layoutY="65.0" prefHeight="200.0" prefWidth="626.0" style="-fx-background-color: #111111; -fx-table-cell-border-color: #333333;">
         <columns>
            <TableColumn fx:id="colId" prefWidth="90" text="ID" />
            <TableColumn fx:id="colUsername" prefWidth="110" text="Username" />
            <TableColumn fx:id="colEmail" prefWidth="140" text="Email" />
            <TableColumn fx:id="colRole" prefWidth="85" text="Role" />
            <TableColumn fx:id="colBalance" prefWidth="80" text="Balance" />
            <TableColumn fx:id="colBlocked" prefWidth="65" text="Blocked" />
         </columns>
      </TableView>
      <HBox layoutX="20.0" layoutY="272.0" spacing="10.0" alignment="CENTER_LEFT">
         <children>
            <Button onAction="#onRefreshUsers" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Làm mới">
               <font><Font size="12.0" /></font>
            </Button>
            <Button onAction="#onBlockUser" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Chặn / Bỏ chặn">
               <font><Font size="12.0" /></font>
            </Button>
            <Button onAction="#onDeleteUser" prefHeight="30.0" prefWidth="110.0" style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Xóa người dùng">
               <font><Font size="12.0" /></font>
            </Button>
            <Label fx:id="userStatusLabel" prefHeight="28.0" prefWidth="200.0" textFill="#eacd8f" />
         </children>
      </HBox>
      <Label layoutX="20.0" layoutY="315.0" text="Vật phẩm" textFill="#d4af5a">
         <font><Font name="Arial Bold" size="14.0" /></font>
      </Label>
      <TableView fx:id="itemTable" layoutX="20.0" layoutY="340.0" prefHeight="140.0" prefWidth="626.0" style="-fx-background-color: #111111; -fx-table-cell-border-color: #333333;">
         <columns>
            <TableColumn fx:id="colItemId" prefWidth="90" text="ID" />
            <TableColumn fx:id="colItemName" prefWidth="160" text="Name" />
            <TableColumn fx:id="colItemCategory" prefWidth="90" text="Category" />
            <TableColumn fx:id="colItemPrice" prefWidth="90" text="Price" />
            <TableColumn fx:id="colItemSeller" prefWidth="100" text="Seller" />
         </columns>
      </TableView>
      <HBox layoutX="20.0" layoutY="487.0" spacing="10.0" alignment="CENTER_LEFT">
         <children>
            <Button onAction="#onRefreshItems" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Làm mới">
               <font><Font size="12.0" /></font>
            </Button>
            <Button onAction="#onDeleteItem" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Xóa vật phẩm">
               <font><Font size="12.0" /></font>
            </Button>
            <Label fx:id="itemStatusLabel" prefHeight="28.0" prefWidth="200.0" textFill="#eacd8f" />
         </children>
      </HBox>
   </children>
</AnchorPane>
