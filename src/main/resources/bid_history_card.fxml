<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox fx:id="cardRoot" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-padding: 12; -fx-background-radius: 5; -fx-border-radius: 5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.BidHistoryCardController">

    <Label fx:id="timeLabel" prefWidth="140" style="-fx-text-fill: #eacd8f; -fx-font-size: 12px;" />
    <Label fx:id="amountLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 16px; -fx-font-weight: bold;" />
    <Label fx:id="auctionLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" />
</HBox>
