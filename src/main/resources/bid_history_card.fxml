<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:id="cardRoot"
      spacing="15" alignment="CENTER_LEFT"
      style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-padding: 12; -fx-background-radius: 5; -fx-border-radius: 5;"
      fx:controller="Controller.BidHistoryCardController">

    <Label fx:id="timeLabel" prefWidth="140" style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
    <Label fx:id="amountLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 16px; -fx-font-weight: bold;" />
    <Label fx:id="auctionLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" />
</HBox>
