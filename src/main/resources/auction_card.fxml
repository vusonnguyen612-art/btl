<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:id="cardRoot"
      spacing="6" alignment="TOP_CENTER"
      style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-padding: 10; -fx-background-radius: 8; -fx-border-radius: 8;"
      fx:controller="Controller.AuctionCardController">

    <ImageView fx:id="itemImageView" fitHeight="130" fitWidth="180" pickOnBounds="true" preserveRatio="true" />

    <Label fx:id="nameLabel" wrapText="true" alignment="CENTER" maxWidth="250"
           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />

    <Label fx:id="priceLabel" alignment="CENTER" maxWidth="250"
           style="-fx-text-fill: #d9b15f; -fx-font-size: 13px;" />

    <Label fx:id="statusLabel" alignment="CENTER"
           style="-fx-text-fill: #4CAF50; -fx-font-size: 12px; -fx-font-weight: bold;" />

    <Label fx:id="timeInfoLabel" alignment="CENTER"
           style="-fx-text-fill: #888888; -fx-font-size: 11px;" />

    <VBox fx:id="actionBox" alignment="CENTER" spacing="5" />
</VBox>
