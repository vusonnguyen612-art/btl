<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox fx:id="cardRoot" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #1a1a1a; -fx-border-color: #d4af5a; -fx-border-width: 1; -fx-padding: 10; -fx-background-radius: 5; -fx-border-radius: 5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.BidCardController">

    <Label fx:id="bidderLabel" prefWidth="100" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px; -fx-font-weight: bold;" />
    <Label fx:id="amountLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 14px; -fx-font-weight: bold;" />
    <Label fx:id="timeLabel" style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
</HBox>
