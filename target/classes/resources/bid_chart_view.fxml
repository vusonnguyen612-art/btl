<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" style="-fx-background-color: #1E1E1D;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.BidChartViewController">
    <children>
        <VBox spacing="10" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label fx:id="auctionNameLabel" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Tên sản phẩm" />

                <HBox spacing="20">
                    <children>
                        <Label fx:id="statusLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 14px;" text="Trạng thái: --" />
                        <Label fx:id="priceLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 16px; -fx-font-weight: bold;" text="Giá cuối: --" />
                        <Label fx:id="endTimeLabel" style="-fx-text-fill: #888888; -fx-font-size: 13px;" text="Kết thúc: --" />
                    </children>
                </HBox>

                <VBox fx:id="chartContainer" prefHeight="250.0" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets bottom="5.0" top="5.0" />
                    </VBox.margin>
                </VBox>

                <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 14px; -fx-font-weight: bold;" text="Chi tiết lượt đặt giá" />

                <ScrollPane fitToWidth="true" prefHeight="150.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="NEVER">
                    <content>
                        <VBox fx:id="bidList" spacing="4" style="-fx-background-color: transparent;" />
                    </content>
                </ScrollPane>

                <HBox alignment="CENTER">
                    <Button onAction="#close" prefWidth="150" prefHeight="38" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" text="Đóng" />
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
