<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #1E1E1D;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AuctionRoomController">

    <children>
        <BorderPane prefHeight="600.0" prefWidth="900.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-border-width: 0 0 2 0;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 24px; -fx-font-weight: bold;" text="PHÒNG ĐẤU GIÁ" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 14px;" text="Số dư:" />
                        <Label fx:id="userBalanceLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 16px; -fx-font-weight: bold;" text="300,000 $" />
                        <Button onAction="#backToList" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" text="Quay lại">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </top>

            <center>
                <HBox spacing="0" fillHeight="true" BorderPane.alignment="CENTER">
                    <children>
                        <VBox prefWidth="300.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-border-width: 0 1 0 0;" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
                            </padding>
                            <children>
                                <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 18px; -fx-font-weight: bold;" text="Các phiên đấu giá">
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </Label>

                                <!-- Search Panel -->
                                <VBox spacing="8" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10;" VBox.vgrow="NEVER">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <TextField fx:id="searchKeywordField" promptText="🔍 Tìm kiếm..." style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 13px;" />
                                        <HBox spacing="5">
                                            <ComboBox fx:id="searchCategoryCombo" promptText="Danh mục" prefWidth="130.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-font-size: 12px;" />
                                            <ComboBox fx:id="searchStatusCombo" promptText="Trạng thái" prefWidth="120.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-font-size: 12px;" />
                                        </HBox>
                                        <HBox spacing="5">
                                            <TextField fx:id="searchMinPriceField" promptText="Giá từ" prefWidth="80.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 12px;" />
                                            <TextField fx:id="searchMaxPriceField" promptText="Giá đến" prefWidth="80.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 12px;" />
                                            <ComboBox fx:id="searchSortCombo" promptText="Sắp xếp" prefWidth="85.0" style="-fx-background-color: #1E1E1D; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-font-size: 12px;" />
                                        </HBox>
                                        <HBox spacing="5">
                                            <Button onAction="#searchAuctions" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-font-size: 12px;" text="Tìm kiếm" HBox.hgrow="ALWAYS" />
                                            <Button onAction="#resetSearch" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-size: 12px;" text="Xóa lọc" HBox.hgrow="ALWAYS" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <ScrollPane fx:id="auctionListScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" focusTraversable="true">
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                    <content>
                                        <VBox fx:id="auctionList" spacing="10" style="-fx-background-color: transparent;" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <VBox fx:id="auctionDetailPane" prefWidth="600.0" style="-fx-background-color: #1E1E1D;" visible="false" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label fx:id="selectedAuctionName" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Tên sản phẩm" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button onAction="#backToList" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 20;" text="X">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Button>
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <VBox.margin>
                                        <Insets bottom="15.0" />
                                    </VBox.margin>
                                    <children>
                                        <Label fx:id="selectedAuctionStatus" style="-fx-text-fill: #eacd8f; -fx-font-size: 14px;" text="Trang thai: RUNNING" />
                                        <Label fx:id="durationDisplayLabel" style="-fx-text-fill: #888888; -fx-font-size: 13px;" text="Thời gian: 60 phút" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER" spacing="30" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 20;">
                                    <VBox.margin>
                                        <Insets bottom="20.0" />
                                    </VBox.margin>
                                    <children>
                                        <VBox alignment="CENTER" spacing="5">
                                            <children>
                                                <Label style="-fx-text-fill: #888888; -fx-font-size: 12px;" text="THỜI GIAN CÒN LẠI" />
                                                <Label fx:id="timerLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 28px; -fx-font-weight: bold;" text="00:00" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="5">
                                            <children>
                                                <Label style="-fx-text-fill: #888888; -fx-font-size: 12px;" text="GIÁ HIỆN TẠI" />
                                                <Label fx:id="currentPriceLabel" style="-fx-text-fill: #4CAF50; -fx-font-size: 28px; -fx-font-weight: bold;" text="100,000 $" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="15">
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                    <children>
                                        <VBox>
                                            <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="BẮT ĐẦU" />
                                            <Label fx:id="startTimeLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" text="--:--" />
                                        </VBox>
                                        <VBox>
                                            <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="KẾT THÚC" />
                                            <Label fx:id="endTimeLabel" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;" text="--:--" />
                                        </VBox>
                                        <VBox>
                                            <Label style="-fx-text-fill: #888888; -fx-font-size: 11px;" text="NGƯỜI RA GIÁ CAO NHẤT" />
                                            <Label fx:id="highestBidderLabel" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" text="Chưa có" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 16px; -fx-font-weight: bold;" text="Đặt giá">
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </Label>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <TextField fx:id="bidAmountField" prefHeight="38.0" prefWidth="180.0" promptText="Nhập số tiền" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 14px;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                        <Button onAction="#placeBid" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 14px;" text="ĐẶT GIÁ" />
                                        <Button onAction="#quickBid" prefHeight="38.0" prefWidth="90.0" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 13px;" text="ĐẶT GIÁ NHANH" />
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="20.0" />
                                    </VBox.margin>
                                </HBox>

                                <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 14px; -fx-font-weight: bold;" text="Tự động trả giá">
                                    <VBox.margin>
                                        <Insets bottom="5.0" />
                                    </VBox.margin>
                                </Label>

                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <children>
                                        <CheckBox fx:id="autoBidCheckBox" style="-fx-text-fill: #eacd8f; -fx-font-size: 13px;" text="Bật" />
                                        <TextField fx:id="autoBidMaxField" prefHeight="32.0" prefWidth="120.0" promptText="Số tiền tối đa" style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 13px;" />
                                        <TextField fx:id="autoBidIncrementField" prefHeight="32.0" prefWidth="100.0" promptText="Thêm $..." style="-fx-background-color: #111111; -fx-border-color: #d4af5a; -fx-background-radius: 10; -fx-border-radius: 10; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-font-size: 13px;" />
                                        <Button fx:id="autoBidButton" onAction="#toggleAutoBid" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #d9b15f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 12px;" text="Xác nhận" />
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="12.0" />
                                    </VBox.margin>
                                </HBox>

                                <VBox fx:id="bidChartContainer" prefHeight="200.0" VBox.vgrow="NEVER">
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </VBox>

                                <Label style="-fx-text-fill: #eacd8f; -fx-font-size: 14px; -fx-font-weight: bold;" text="Lịch sử đặt giá">
                                    <VBox.margin>
                                        <Insets bottom="5.0" />
                                    </VBox.margin>
                                </Label>

                                <ScrollPane fx:id="bidHistoryScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" focusTraversable="true">
                                    <content>
                                        <VBox fx:id="bidHistoryList" spacing="5" style="-fx-background-color: transparent;" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
